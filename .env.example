# ARHA Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to version control.

# ----- Application -----
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----- Database -----
# Local development example:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/arha
# Neon/Supabase example:
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/arha

# ----- AI APIs -----
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ----- Notifications -----
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
TELEGRAM_BOT_TOKEN=123456:ABC...

# ----- CORS & Hosts -----
# Comma-separated origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
# Comma-separated allowed hosts (production only)
ALLOWED_HOSTS=your-api.onrender.com
