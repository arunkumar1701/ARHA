# ARHA Environment Configuration
# Copy this file to .env and fill in your actual values for local development

# ---- Core Configuration ----
ARHA_ENV=development
SECRET_KEY=your-secret-key-minimum-32-characters-required-12345
ARHA_PASSPHRASE=your-passphrase-minimum-16-characters-123456

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/arha_db

# ---- Frontend ----
ARHA_FRONTEND_URL=http://localhost:5173

# ---- OpenAI API ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ---- Search & Research ----
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key

# ---- Caching (Upstash Redis) ----
UPSTASH_REDIS_URL=https://your-upstash-redis-url:port
UPSTASH_REDIS_TOKEN=your-upstash-token

# ---- Notifications ----
SENDGRID_API_KEY=sg-your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@example.com
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ---- Admin ----
ADMIN_EMAIL=admin@example.com

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Rate Limiting & Upload ----
RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_BYTES=5242880
